generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Game Data: Items ─────────────────────────────────────────────

model Item {
  id            Int      @id // Item ID from rAthena/GRF
  aegisName     String   @default("") // rAthena internal name
  name          String   // English name
  namePt        String?  // Portuguese (LATAM) name from GRF
  type          ItemType
  subType       String?
  weight        Float    @default(0)
  atk           Int?
  matk          Int?
  defense       Int?
  range         Int?
  slots         Int      @default(0)
  equipLevelMin Int?
  equipLevelMax Int?
  weaponLevel   Int?
  armorLevel    Int?
  buy           Int?
  sell          Int?
  jobs          String[] // Job flags that can equip
  classes       String[] // Class restrictions (All, Normal, Upper, etc.)
  locations     String[] // Equipment locations (Right_Hand, Body, etc.)
  description   String[] // pt-BR description lines from GRF
  script        String?  // rAthena equip/use script
  equipScript   String?  // rAthena on-equip script
  refineable    Boolean  @default(false)
  gradable      Boolean  @default(false)
  costume       Boolean  @default(false)
  classNum      Int      @default(0) // Sprite class number
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  buildItems    BuildItem[]
  drops         MonsterDrop[]

  @@index([type])
  @@index([name])
  @@index([aegisName])
  @@index([namePt])
}

// ─── Game Data: Monsters ──────────────────────────────────────────

model Monster {
  id            Int      @id // Monster ID
  aegisName     String   @unique
  name          String   // English name
  namePt        String?  // Portuguese name (future: from GRF)
  level         Int      @default(1)
  hp            Int      @default(1)
  sp            Int      @default(0)
  baseExp       Int      @default(0)
  jobExp        Int      @default(0)
  mvpExp        Int      @default(0)
  attack        Int      @default(0)
  magicAttack   Int      @default(0)
  defense       Int      @default(0)
  magicDefense  Int      @default(0)
  str           Int      @default(0)
  agi           Int      @default(0)
  vit           Int      @default(0)
  int_          Int      @default(0) @map("int")
  dex           Int      @default(0)
  luk           Int      @default(0)
  attackRange   Int      @default(0)
  skillRange    Int      @default(0)
  chaseRange    Int      @default(0)
  size          String   @default("Small") // Small, Medium, Large
  race          String   @default("Formless")
  element       String   @default("Neutral")
  elementLevel  Int      @default(1)
  walkSpeed     Int      @default(200)
  attackDelay   Int      @default(0)
  attackMotion  Int      @default(0)
  damageMotion  Int      @default(0)
  ai            String   @default("06")
  class         String   @default("Normal") // Normal, Boss, Guardian
  isMvp         Boolean  @default(false)
  modes         String[] // Special behavior flags
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  drops         MonsterDrop[]
  mvpDrops      MonsterMvpDrop[]

  @@index([name])
  @@index([level])
  @@index([race])
  @@index([element])
  @@index([isMvp])
}

model MonsterDrop {
  id             String  @id @default(cuid())
  monsterId      Int
  itemId         Int
  rate           Int     // Drop rate (10000 = 100%)
  stealProtected Boolean @default(false)

  monster        Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  item           Item    @relation(fields: [itemId], references: [id])

  @@index([monsterId])
  @@index([itemId])
}

model MonsterMvpDrop {
  id        String  @id @default(cuid())
  monsterId Int
  aegisName String  // Item aegis name (may not exist in our Item table)
  rate      Int

  monster   Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@index([monsterId])
}

// ─── Game Data: Skills ────────────────────────────────────────────

model Skill {
  id          Int      @id // Skill ID
  aegisName   String   @unique // e.g. SM_BASH, MG_FIREBOLT
  name        String   // Description/display name
  namePt      String?  // Portuguese name (future)
  maxLevel    Int      @default(1)
  type        String   @default("None") // Weapon, Magic, Misc, None
  targetType  String   @default("Passive") // Self, Attack, Ground, Passive, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([aegisName])
  @@index([type])
}

// ─── Classes ─────────────────────────────────────────────────────

model JobClass {
  id          String   @id // e.g. "archbishop", "ranger", "warlock"
  name        String
  namePt      String?
  tree        String   // e.g. "acolyte > priest > archbishop"
  baseClass   String?
  icon        String?
  description String?
  roles       String[] // support, dps, tank, utility

  builds      Build[]
}

// ─── Builds ───────────────────────────────────────────────────────

model Build {
  id            String     @id @default(cuid())
  title         String
  jobClassId    String
  patch         String     // e.g. "2025-10"
  role          String     // mvp, woe, pve, pvp
  score         Float?     // Meta score 0-10
  isAiGenerated Boolean    @default(false)
  description   String?
  statPoints    Json?      // { str, agi, vit, int, dex, luk }
  skillPoints   Json?      // { skillId: level }
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  jobClass      JobClass   @relation(fields: [jobClassId], references: [id])
  items         BuildItem[]

  @@index([jobClassId])
  @@index([patch])
  @@index([role])
}

model BuildItem {
  id       String @id @default(cuid())
  buildId  String
  itemId   Int
  slot     String // head_top, head_mid, head_low, body, weapon, offhand, garment, shoes, acc1, acc2
  refine   Int    @default(0)
  cards    Int[]  // Card Item IDs in each slot
  enchants Json?  // Enchantment selections

  build    Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)
  item     Item   @relation(fields: [itemId], references: [id])

  @@index([buildId])
}

// ─── Meta ─────────────────────────────────────────────────────────

model MetaSnapshot {
  id          String   @id @default(cuid())
  patch       String
  snapshotAt  DateTime @default(now())
  tierList    Json     // { jobClassId: { role: "S/A/B/C/D", notes: "..." } }
  topBuilds   Json     // Top build IDs per class
  changes     String?  // What changed from previous patch
  sources     String[] // URLs or references
}

// ─── Enums ────────────────────────────────────────────────────────

enum ItemType {
  WEAPON
  ARMOR
  CARD
  CONSUMABLE
  HEALING
  USABLE
  DELAYCONSUME
  QUEST
  MISC
  AMMUNITION
  SHADOW
  UNKNOWN
}
